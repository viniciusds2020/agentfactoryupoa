# Agent Factory — Configuração mínima
# Copie este arquivo para .env e preencha sua chave da Groq.
# Obtenha uma chave gratuita em: https://console.groq.com/keys

GROQ_API_KEY=gsk_sua_chave_aqui

# ── Configurações avançadas (opcionais) ──────────────────────────
# Descomente e ajuste somente se necessário.

# SIMPLE_MODE=true
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile
# ANTHROPIC_API_KEY=
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
# FAISS_INDEX_TYPE=flat
# FAISS_HNSW_M=32
# FAISS_HNSW_EF_CONSTRUCTION=200
# FAISS_HNSW_EF_SEARCH=64
# RETRIEVAL_TOP_K=15
# DEFAULT_DOMAIN_PROFILE=general
# ENVIRONMENT=development
# LOG_LEVEL=INFO

# ── Melhorias de retrieval (todas off por default) ──────────────
# RERANKER_ENABLED=false
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# RERANKER_TOP_K=10
# QUERY_EXPANSION_ENABLED=false
# QUERY_EXPANSION_MAX_REFORMULATIONS=2
# HYDE_ENABLED=false
# HYDE_MERGE_ORIGINAL=true
# ADAPTIVE_WEIGHTS_ENABLED=false
# COMPRESSION_ENABLED=false
# COMPRESSION_METHOD=extractive
# COMPRESSION_MAX_SENTENCES=3
